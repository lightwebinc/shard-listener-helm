{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "bitcoin-shard-listener values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "workloadType": { "type": "string", "enum": ["Deployment", "DaemonSet"] },
    "replicaCount": { "type": "integer", "minimum": 0 },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "tag": { "type": "string" }
      },
      "required": ["repository", "pullPolicy"]
    },
    "networking": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["multus", "host", "unicast"] }
      },
      "required": ["mode"]
    },
    "config": {
      "type": "object",
      "properties": {
        "listenPort":  { "type": "integer", "minimum": 1, "maximum": 65535 },
        "shardBits":   { "type": "integer", "minimum": 1, "maximum": 15 },
        "mcScope":     { "type": "string", "enum": ["link", "site", "org", "global"] },
        "egressProto": { "type": "string", "enum": ["udp", "tcp"] },
        "headerEgressProto": { "type": "string", "enum": ["udp", "tcp"] },
        "beaconScope": { "type": "string", "enum": ["link", "site", "org", "global"] },
        "numWorkers":  { "type": "integer", "minimum": 1, "maximum": 1,
                         "description": "MUST be 1; multiple workers cause SO_REUSEPORT multicast duplication" },
        "debug":       { "type": "boolean" }
      }
    }
  }
}
